{
  "name": "@portfolio/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun next dev",
    "prebuild": "bun --bun scripts/velite-build.mjs",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "check-types": "tsc --noEmit",
    "prelint": "bun run prebuild",
    "lint": "biome check --error-on-warnings .",
    "prelint:fix": "bun run prebuild",
    "lint:fix": "biome check --write --error-on-warnings .",
    "test": "bun test",
    "test:a11y": "playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@icons-pack/react-simple-icons": "^13.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "motion": "^12.29.2",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^3.8.1",
    "shiki": "^3.22.0",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "velite": "^0.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@davidvornholt/a11y-testing": "workspace:*",
    "@davidvornholt/typescript-config": "workspace:*",
    "@jridgewell/trace-mapping": "^0.3.31",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "5.9.3"
  }
}
